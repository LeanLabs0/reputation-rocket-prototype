{
  "redirects": [
    {
      "source": "/eimmigration",
      "destination": "/eimmigration/",
      "permanent": true
    },
    {
      "source": "/katapult",
      "destination": "/katapult/",
      "permanent": true
    },
    {
      "source": "/lean-labs",
      "destination": "/lean-labs/",
      "permanent": true
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "Permissions-Policy",
          "value": "camera=(), microphone=(), geolocation=()"
        }
      ]
    }
  ]
}
